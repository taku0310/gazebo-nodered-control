  {
    "id": "fnCmd",
    "type": "function",
    "z": "tabRobot",
    "name": "direction → cmd_vel JSON",
    "func": "const speed = Number(flow.get('speed'));\nconst v = Number.isFinite(speed) ? speed : 1.0;\nconst map = {\n    forward:  { linear_x:  v, angular_z: 0 },\n    backward: { linear_x: -v, angular_z: 0 },\n    left:     { linear_x:  0, angular_z:  v },\n    right:    { linear_x:  0, angular_z: -v },\n    stop:     { linear_x:  0, angular_z: 0 }\n};\nconst dir = String(msg.payload);\nconst cmd = map[dir];\nif (!cmd) {\n    node.warn('unknown direction: ' + dir);\n    return null;\n}\nreturn { topic: 'robot/cmd_vel', payload: cmd };\n",
    "outputs": 1,
    "noerr": 0,
    "initialize": "flow.set('speed', 1.0);",
    "finalize": "",
    "libs": [],
    "x": 420,
    "y": 320,
    "wires": [["mqttOutCmd"]]
  },
  {
    "id": "mqttOutCmd",
    "type": "mqtt out",
    "z": "tabRobot",
    "name": "publish robot/cmd_vel",
    "topic": "",
    "qos": "1",
    "retain": "false",
    "respTopic": "",
    "contentType": "",
    "userProps": "",
    "correl": "",
    "expiry": "",
    "broker": "brokerMosquitto",
