  {
    "id": "cssInject",
    "type": "ui_template",
    "z": "tabRobot",
    "group": "uiGroupDrive",
    "name": "global CSS",
    "order": 0,
    "width": 0,
    "height": 0,
    "format": "<style>\n  body.nr-dashboard-theme md-toolbar.md-default-theme,\n  body.nr-dashboard-theme md-toolbar {\n    background: linear-gradient(90deg, #1565C0 0%, #00838F 100%) !important;\n  }\n  .nr-dashboard-cardpanel {\n    border-radius: 12px !important;\n    box-shadow: 0 8px 24px rgba(0,0,0,0.35) !important;\n    border: 1px solid rgba(255,255,255,0.04) !important;\n    background: linear-gradient(160deg, #1a1f2b 0%, #0e1117 100%) !important;\n  }\n  .nr-dashboard-cardpanel md-card-title {\n    background: rgba(66,165,245,0.08);\n    border-bottom: 1px solid rgba(66,165,245,0.15);\n    border-radius: 12px 12px 0 0;\n  }\n  .nr-dashboard-cardpanel md-card-title .md-title {\n    letter-spacing: 2px;\n    font-weight: 700;\n    color: #90CAF9 !important;\n  }\n  .nr-dashboard-button button.md-button {\n    border-radius: 14px !important;\n    font-weight: 700;\n    letter-spacing: 1px;\n    text-transform: uppercase;\n    box-shadow: 0 4px 14px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.08);\n    transition: transform 80ms ease-out, box-shadow 80ms ease-out, filter 80ms ease-out;\n  }\n  .nr-dashboard-button button.md-button:hover {\n    filter: brightness(1.1);\n    box-shadow: 0 6px 18px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.1);\n  }\n  .nr-dashboard-button button.md-button:active {\n    transform: translateY(2px);\n    box-shadow: 0 2px 6px rgba(0,0,0,0.4);\n  }\n  .nr-dashboard-button .md-button .ng-binding,\n  .nr-dashboard-button .md-button i {\n    font-size: 1.3em;\n  }\n  .nr-dashboard-button .md-button i {\n    margin-right: 6px;\n  }\n  .status-pill {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 10px;\n    padding: 14px 18px;\n    border-radius: 12px;\n    font-weight: 700;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    box-shadow: 0 4px 14px rgba(0,0,0,0.4);\n  }\n  .status-pill .dot {\n    width: 12px;\n    height: 12px;\n    border-radius: 50%;\n    box-shadow: 0 0 0 0 currentColor;\n    animation: pulse 1.8s infinite;\n  }\n  .status-pill.online { background: linear-gradient(135deg, #1B5E20, #2E7D32); color: #B9F6CA; }\n  .status-pill.offline { background: linear-gradient(135deg, #B71C1C, #C62828); color: #FFCDD2; }\n  @keyframes pulse {\n    0%   { box-shadow: 0 0 0 0 rgba(255,255,255,0.4); }\n    70%  { box-shadow: 0 0 0 10px rgba(255,255,255,0); }\n    100% { box-shadow: 0 0 0 0 rgba(255,255,255,0); }\n  }\n  .telemetry-row {\n    display: grid;\n    grid-template-columns: 70px 1fr;\n    align-items: center;\n    padding: 10px 12px;\n    border-radius: 10px;\n    background: rgba(255,255,255,0.03);\n    margin-top: 8px;\n    font-family: 'SF Mono', 'JetBrains Mono', Menlo, Consolas, monospace;\n  }\n  .telemetry-row .label {\n    color: #90CAF9;\n    font-weight: 700;\n    letter-spacing: 1px;\n    font-size: 0.85em;\n  }\n  .telemetry-row .value { color: #E3F2FD; font-size: 0.95em; }\n  .alarm-card {\n    margin-top: 10px;\n    padding: 12px 14px;\n    border-left: 4px solid #FFB300;\n    background: rgba(255,179,0,0.08);\n    border-radius: 8px;\n    color: #FFE082;\n    font-weight: 600;\n  }\n  .alarm-card.clear {\n    border-left-color: #2E7D32;\n    background: rgba(46,125,50,0.08);\n    color: #B9F6CA;\n  }\n</style>",
    "storeOutMessages": true,
    "fwdInMessages": true,
    "resendOnRefresh": true,
    "templateScope": "global",
    "className": "",
    "x": 130,
    "y": 60,
    "wires": [[]]
  },
