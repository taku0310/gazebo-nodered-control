# Copy to .env and adjust as needed.

# Bind addresses (use 0.0.0.0 only on trusted networks).
MQTT_BIND=127.0.0.1
MQTT_WS_BIND=127.0.0.1
NODERED_BIND=127.0.0.1
GAZEBO_WEB_BIND=127.0.0.1

# Shared DDS domain. All ROS 2 nodes must agree.
ROS_DOMAIN_ID=42

# Software OpenGL is robust inside Docker. Set 0 if you have a GPU
# passthrough (Linux + nvidia-container-toolkit).
LIBGL_ALWAYS_SOFTWARE=1

# Virtual framebuffer resolution served via noVNC.
XVFB_RESOLUTION=1280x800x24

TZ=Asia/Tokyo
