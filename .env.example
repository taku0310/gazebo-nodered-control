# Copy to .env and adjust as needed.

# Bind addresses (use 0.0.0.0 only on trusted networks).
MQTT_BIND=127.0.0.1
MQTT_WS_BIND=127.0.0.1
NODERED_BIND=127.0.0.1

# Shared DDS domain. All ROS 2 nodes must agree.
ROS_DOMAIN_ID=42

# Set to 0 if you want to launch gzclient with X11 forwarding.
GAZEBO_HEADLESS=1

# Software GL is robust in containers. Set 0 if you have a passthrough GPU.
LIBGL_ALWAYS_SOFTWARE=1

TZ=Asia/Tokyo
